# Flask application environment file
# Generated by Ansible

# Database Configuration
DATABASE_URL=postgresql://{{ postgres_user }}:{{ postgres_password }}@{{ groups['dbservers'][0] }}:5432/microblog_db

# Redis Configuration
REDIS_URL=redis://:{{ redis_requirepass }}@{{ groups['cacheservers'][0] }}:6379/0

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://{{ groups['searchservers'][0] }}:9200

# Flask Configuration
FLASK_ENV={{ app_env }}
FLASK_APP=microblog.py
SECRET_KEY={{ secret_key | default('change-me-to-a-random-secret-key') }}
LOG_TO_STDOUT=1

# Mail Configuration
MAIL_SERVER={{ mail_server | default('smtp.gmail.com') }}
MAIL_PORT={{ mail_port | default('587') }}
MAIL_USE_TLS={{ mail_use_tls | default('1') }}
MAIL_USERNAME={{ mail_username | default('') }}
MAIL_PASSWORD={{ mail_password | default('') }}

# Microsoft Translator Configuration
MS_TRANSLATOR_KEY={{ ms_translator_key | default('') }}

# Application Settings
SERVER_NAME={{ server_name | default('') }}

# Admins
ADMINS=lytreetree@gmail.com

# Posts per page
POSTS_PER_PAGE=25
