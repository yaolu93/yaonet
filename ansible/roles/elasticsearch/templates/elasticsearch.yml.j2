# Elasticsearch configuration
# Generated by Ansible

cluster.name: {{ elasticsearch_cluster_name }}
node.name: {{ elasticsearch_node_name }}

# Network settings
network.host: [_local_, _site_]
network.bind_host: {{ elasticsearch_bind }}
http.port: {{ elasticsearch_port }}

# Node settings
node.roles: [{{ elasticsearch_node_master | ternary('master', '') }}, {{ elasticsearch_node_data | ternary('data', '') }}]

# Discovery settings
discovery.type: {{ elasticsearch_discovery_type }}

# Xpack security settings
xpack.security.enabled: {{ elasticsearch_xpack_security_enabled | lower }}
xpack.security.enrollment.enabled: {{ elasticsearch_xpack_security_enrollment_enabled | lower }}

# Memory settings
indices.memory.index_buffer_size: {{ elasticsearch_indices_memory_index_buffer_size }}

# Logging
logger.level: {{ elasticsearch_log_level }}
path.logs: {{ elasticsearch_logdir }}

# Path configuration
path.data: /var/lib/elasticsearch
path.home: /usr/share/elasticsearch
