# Nginx site configuration for Yaonet application
# Generated by Ansible

upstream gunicorn {
    server unix:{{ app_path }}/gunicorn.sock fail_timeout=0;
}

# HTTP to HTTPS redirect
server {
    listen 80;
    listen [::]:80;
    server_name {{ server_name | default('_') }};
    
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }
    
    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS server block
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ server_name | default('_') }};

    # SSL Configuration
    ssl_certificate /etc/nginx/ssl/certificate.crt;
    ssl_certificate_key /etc/nginx/ssl/private.key;
    
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    # Security headers
    include /etc/nginx/snippets/security-headers.conf;

    # Logging
    access_log {{ log_dir }}/nginx/yaonet_access.log;
    error_log {{ log_dir }}/nginx/yaonet_error.log;

    # Root directory
    root {{ app_path }};

    # Rate limiting
    limit_req zone=general burst=20 nodelay;

    # Static files with long expiration
    location ~ ^/(static|images)/ {
        expires 30d;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # Disable access to hidden files
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Disable access to backup/config files
    location ~ ~$ {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Disable access to .env file
    location ~ \.env {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Main application proxy settings
    location / {
        # Proxy parameters
        include /etc/nginx/snippets/proxy-params.conf;
        
        proxy_pass http://gunicorn;
        proxy_redirect off;
        
        # Limit request methods
        limit_except GET HEAD POST PUT DELETE {
            deny all;
        }
    }

    # Health check endpoint
    location /health {
        access_log off;
        return 200 "healthy\n";
        add_header Content-Type text/plain;
    }
}
