# Google Cloud Run Deployment - Environment Variables
# This file stores your cloud deployment credentials
# 📝 IMPORTANT: Fill in your actual values from Neon, Upstash, and GCP
# 🔒 This file is git-ignored for security

# ==========================================
# 1. GOOGLE CLOUD PROJECT
# ==========================================
# Get from: https://console.cloud.google.com
# It's shown in the project selector dropdown
# Example: microblog-production-abc123
GCP_PROJECT_ID="your-gcp-project-id-here"

# ==========================================
# 2. DOCKER HUB CREDENTIALS
# ==========================================
# Your Docker Hub username (not email)
# Used for pushing images
# Example: yaouser
DOCKER_USERNAME="your-docker-hub-username"

# ==========================================
# 3. DATABASE (Neon PostgreSQL)
# ==========================================
# Get from: https://app.neon.tech
# Click on your project → Connection string
# Format: postgresql://user:password@ep-xxxxx.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxxxx.xx.neon.tech/neondb?sslmode=require"

# ==========================================
# 4. REDIS (Upstash)
# ==========================================
# Get from: https://console.upstash.com
# Click on Redis → Details → REST API
# Format: redis://:password@hostname:port
REDIS_URL="redis://:password@hostname:port"

# ==========================================
# 5. OPTIONAL: APPLICATION SETTINGS
# ==========================================
# Usually keep these as-is for Cloud Run
FLASK_ENV="production"
LOG_TO_STDOUT="true"
RUN_MIGRATIONS="true"

# ==========================================
# 6. OPTIONAL: EMAIL SERVICE (Gmail)
# ==========================================
# For password reset emails
# MAIL_SERVER="smtp.gmail.com"
# MAIL_PORT="587"
# MAIL_USE_TLS="true"
# MAIL_USERNAME="your-email@gmail.com"
# MAIL_PASSWORD="your-app-specific-password"

# ==========================================
# 7. OPTIONAL: ELASTICSEARCH
# ==========================================
# For full-text search (requires paid plan)
# ELASTICSEARCH_URL="https://your-cluster:9200"

# ==========================================
# DO NOT EDIT BELOW - Used by scripts
# ==========================================
# These are set automatically
CLOUD_DEPLOYMENT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$CLOUD_DEPLOYMENT_DIR")"
