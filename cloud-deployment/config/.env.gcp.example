# Google Cloud Run - Environment Variables Template
# Copy this to .env.gcp and fill in your actual values

# ==========================================
# DATABASE (Neon PostgreSQL)
# ==========================================
# Get this from: https://app.neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxxx.xx.neon.tech/microblog?sslmode=require

# ==========================================
# REDIS (Upstash)
# ==========================================
# Get this from: https://console.upstash.com
# Format: redis://:password@host:port
REDIS_URL=redis://:password@host:port

# ==========================================
# APPLICATION SETTINGS
# ==========================================
FLASK_ENV=production
LOG_TO_STDOUT=true
RUN_MIGRATIONS=true

# ==========================================
# OPTIONAL: EMAIL CONFIGURATION
# ==========================================
# For sending password reset emails, etc.
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

# ==========================================
# OPTIONAL: TRANSLATION SERVICE
# ==========================================
# For translating posts between languages
# MS_TRANSLATOR_KEY=your-microsoft-translator-key

# ==========================================
# OPTIONAL: ELASTICSEARCH
# ==========================================
# For full-text search functionality
# ELASTICSEARCH_URL=https://your-elasticsearch-cluster:9200

# ==========================================
# APPLICATION CONFIG
# ==========================================
SECRET_KEY=your-secret-key-here-change-in-production
LANGUAGES=en,es
POSTS_PER_PAGE=25

# ==========================================
# ADMIN EMAIL
# ==========================================
# For error notifications
ADMINS=your-email@example.com

# ==========================================
# DEPLOYMENT INFO
# ==========================================
# Leave empty for localhost
SERVER_NAME=yourdomain.com
