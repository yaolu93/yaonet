# Copy this file to .env.observability and fill your real tokens/endpoints.

# Splunk Observability OTLP (minimal mode)
SPLUNK_OTLP_ENDPOINT=https://ingest.<realm>.signalfx.com/v2/trace/otlp
SPLUNK_ACCESS_TOKEN=

# Optional global OTLP headers used by Flask exporter (comma-separated key=value)
OTEL_EXPORTER_OTLP_HEADERS=
